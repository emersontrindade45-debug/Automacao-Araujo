# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.worktrees/
src/

# supabase
supabase/.temp/

.vercel

# MCP config (contém API keys)
.mcp.json

# Claude Code internals
.claude/
.superpowers/
*export_temp*
n8n-skills/
.agents/
skills-lock.json

# Temporary n8n workflow downloads
n8n/workflows/fluxo*_current*.json
n8n/workflows/fluxo*_fixed.json
n8n/workflows/fluxo*_final.json
n8n/workflows/fluxo*_put*.json
n8n/workflows/fluxo*_upload.json

# Scripts de patch n8n (contêm chaves hardcoded)
n8n/patch_*.py
n8n/scripts/deploy-*.js

# Dados de produtos (arquivos grandes e CSVs gerados)
dados/*.xlsx
dados/*.csv
dados/*.log
dados/__pycache__/
dados/nomes_no_banco.txt
