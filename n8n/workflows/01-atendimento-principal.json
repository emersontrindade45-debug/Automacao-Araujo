    {
      "id": "node-normalizar",
      "name": "Normalizar Payload",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [460, 300],
      "parameters": {
        "jsCode": "const body = $input.first().json.body || $input.first().json;\nconst data = body.data || body;\n\nconst remoteJid = data.key?.remoteJid || data.remoteJid || body.telefone || '';\nconst telefone = remoteJid.replace('@s.whatsapp.net', '').replace('@g.us', '');\n\nconst mensagem = data.message?.conversation\n  || data.message?.extendedTextMessage?.text\n  || body.mensagem\n  || '[midia]';\n\nconst nome_cliente = data.pushName\n  || data.pushname\n  || body.nome_cliente\n  || 'Cliente';\n\nreturn [{ json: { telefone, mensagem, nome_cliente, canal: 'whatsapp' } }];"
      }
    },
    {
      "id": "node-buscar-cliente",
      "name": "Buscar Cliente",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [700, 200],
      "parameters": {
        "method": "GET",
        "url": "={{ $vars.SUPABASE_URL }}/rest/v1/clientes",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {"name": "telefone", "value": "=eq.{{ $json.telefone }}"},
            {"name": "select", "value": "*"}
          ]
        },
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {"name": "apikey", "value": "={{ $vars.SUPABASE_SERVICE_ROLE_KEY }}"},
            {"name": "Authorization", "value": "=Bearer {{ $vars.SUPABASE_SERVICE_ROLE_KEY }}"}
          ]
        },
        "options": {}
      },
      "onError": "continueRegularOutput"
    },
    {
      "id": "node-catalogo-hub",
      "name": "Buscar Catalogo Hub",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [700, 400],
      "parameters": {
        "method": "GET",
        "url": "={{ $vars.HUB_URL }}/api/produtos",
        "options": {}
      },
      "onError": "continueRegularOutput"
    },
    {
      "id": "node-montar-contexto",
      "name": "Montar Contexto",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [940, 300],
      "parameters": {
        "jsCode": "const payload = $('Normalizar Payload').item.json;\nconst clienteData = $('Buscar Cliente').item.json;\nconst catalogoHub = $('Buscar Catalogo Hub').item.json;\n\nconst clientes = Array.isArray(clienteData) ? clienteData : [clienteData];\nconst cliente = clientes[0] || {};\nconst etapa_atual = cliente.etapa || 'novo';\n\nlet catalogo = [];\nif (Array.isArray(catalogoHub)) {\n  catalogo = catalogoHub;\n} else if (catalogoHub?.produtos) {\n  catalogo = catalogoHub.produtos;\n} else if (catalogoHub?.data) {\n  catalogo = catalogoHub.data;\n}\n\nconst catalogo_formatado = catalogo.length > 0\n  ? catalogo.map(p => `- ${p.nome}: R$ ${p.preco} (${p.unidade || 'un'})`).join('\\n')\n  : 'Catalogo indisponivel no momento.';\n\nreturn [{\n  json: {\n    ...payload,\n    etapa_atual,\n    catalogo_formatado,\n    cliente_id: cliente.id || null\n  }\n}];"
      }
    },
    {
      "id": "node-ia-atendimento",
      "name": "IA Atendimento",
      "type": "@n8n/n8n-nodes-langchain.openAi",
      "typeVersion": 1.8,
      "position": [1160, 300],
      "parameters": {
        "resource": "text",
        "operation": "message",
        "modelId": {
          "__rl": true,
          "value": "gpt-4o",
          "mode": "list",
          "cachedResultName": "GPT-4O"
        },
        "messages": {
          "values": [
            {
              "role": "system",
              "content": "=Voce e um atendente virtual de uma loja de varejo. Seja cordial, objetivo e profissional.\n\nCatalogo atual:\n{{ $json.catalogo_formatado }}\n\nCliente: {{ $json.nome_cliente }} | Etapa atual: {{ $json.etapa_atual }}\n\nResponda naturalmente como atendente. Retorne SOMENTE JSON valido sem markdown:\n{\"resposta\": \"...\", \"intencao\": \"saudacao|consulta_preco|fazer_pedido|fora_escopo|humano\"}"
            },
            {
              "role": "user",
              "content": "={{ $json.mensagem }}"
            }
          ]
        },
        "options": {}
      },
      "credentials": {
        "openAiApi": {
          "id": "xxXa5gXpf4dM4Smm",
          "name": "OpenAI"
        }
      }
    },
    {
      "id": "node-parse-ia",
      "name": "Parse IA",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1380, 300],
      "parameters": {
        "jsCode": "const raw = $input.first().json.message?.content || $input.first().json.text || '{}';\nlet parsed;\ntry {\n  const clean = raw.replace(/```json\\n?/g, '').replace(/```\\n?/g, '').trim();\n  parsed = JSON.parse(clean);\n} catch(e) {\n  parsed = { resposta: 'Desculpe, nao entendi. Pode repetir?', intencao: 'fora_escopo' };\n}\n\nconst payload = $('Montar Contexto').item.json;\n\nreturn [{\n  json: {\n    ...payload,\n    resposta: parsed.resposta || 'Ola! Como posso ajudar?',\n    intencao: parsed.intencao || 'fora_escopo'\n  }\n}];"
      }
    },
    {
