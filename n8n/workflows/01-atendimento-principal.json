    {
      "id": "node-wh-entrada",
      "name": "Webhook Entrada",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2.1,
      "position": [240, 300],
      "parameters": {
        "httpMethod": "POST",
        "path": "atendimento-entrada",
        "responseMode": "responseNode",
        "options": {}
      },
      "onError": "continueRegularOutput",
