    {
      "id": "node-preparar-texto",
      "name": "Preparar Texto Admin",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1560, 440],
      "parameters": {
        "jsCode": "const fromAudio = $('Whisper Transcricao').item?.json?.text || '';\nconst fromText = $('Normalizar Payload F6').item.json.mensagem || '';\n\nconst textoCompleto = fromAudio || fromText;\nconst textoLimpo = textoCompleto.replace(/^#admin\\s*/i, '').trim();\n\nconst payload = $('Normalizar Payload F6').item.json;\n\nreturn [{ json: { ...payload, textoAdmin: textoLimpo } }];"
      }
    },
    {
      "id": "node-agente-classificar",
      "name": "Agente Classificar Intencao",
      "type": "@n8n/n8n-nodes-langchain.openAi",
      "typeVersion": 1.8,
      "position": [1780, 440],
      "parameters": {
        "modelId": "gpt-4o-mini",
        "messages": {
          "values": [
            {
              "role": "system",
              "content": "Você é um classificador de comandos de atualização de base de conhecimento de uma loja.\n\nAnalise o texto do dono e retorne SOMENTE JSON válido, sem markdown:\n{\n  \"categoria\": \"faq\" | \"produto\" | \"configuracao\",\n  \"acao\": \"atualizar\" | \"adicionar\" | \"remover\",\n  \"dados\": {\n    \"chave\": \"identificador único do item (pergunta para faq, nome para produto, chave para config)\",\n    \"valor\": \"novo valor ou descrição (null se for remover)\"\n  }\n}\n\nExemplos:\n- 'horário amanhã é até 17h' → {\"categoria\":\"faq\",\"acao\":\"atualizar\",\"dados\":{\"chave\":\"Qual o horário de funcionamento?\",\"valor\":\"Segunda a sábado das 7h às 19h, mas amanhã fecha às 17h.\"}}\n- 'adiciona alcatra a R$75 o kg' → {\"categoria\":\"produto\",\"acao\":\"adicionar\",\"dados\":{\"chave\":\"Alcatra\",\"valor\":\"75.00|kg|sim\"}}\n- 'remove frango do cardápio' → {\"categoria\":\"produto\",\"acao\":\"remover\",\"dados\":{\"chave\":\"Frango inteiro\",\"valor\":null}}\n- 'entregamos até 8km' → {\"categoria\":\"configuracao\",\"acao\":\"atualizar\",\"dados\":{\"chave\":\"area_entrega\",\"valor\":\"Raio de 8km do centro\"}}"
            },
            {
              "content": "={{ $json.textoAdmin }}"
            }
          ]
        },
        "options": {}
      },
      "credentials": {
        "openAiApi": { "id": "52clkHx8T3QEMNnB", "name": "OpenAI Araujo" }
      }
    },
    {
      "id": "node-parse-intencao",
      "name": "Parse Intencao",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2000, 440],
      "parameters": {
        "jsCode": "const raw = $input.first().json.message?.content || $input.first().json.text || '{}';\nlet parsed;\ntry {\n  const clean = raw.replace(/```json\\n?/g, '').replace(/```\\n?/g, '').trim();\n  parsed = JSON.parse(clean);\n} catch(e) {\n  parsed = { categoria: 'faq', acao: 'atualizar', dados: { chave: 'erro', valor: 'Não foi possível interpretar o comando.' } };\n}\n\nconst payload = $('Preparar Texto Admin').item.json;\n\nreturn [{ json: { ...payload, ...parsed } }];"
      }
    },
