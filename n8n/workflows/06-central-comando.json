    {
      "id": "node-toggle-ia",
      "name": "Toggle IA",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1120, 160],
      "parameters": {
        "jsCode": "const payload = $('Normalizar Payload F6').item.json;\nconst estadoAtual = $input.first().json;\nconst rows = Array.isArray(estadoAtual) ? estadoAtual : [estadoAtual];\nconst iaAtiva = rows[0]?.ia_ativa ?? true;\nconst novoEstado = !iaAtiva;\n\nreturn [{ json: { telefone: payload.telefone, ia_ativa: novoEstado, novoEstado } }];"
      }
    },
