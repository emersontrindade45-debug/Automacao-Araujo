    {
      "id": "node-normalizar-f6",
      "name": "Normalizar Payload F6",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [460, 300],
      "parameters": {
        "jsCode": "const body = $input.first().json.body || $input.first().json;\nconst data = body.data || body;\n\nconst remoteJid = data.key?.remoteJid || data.remoteJid || body.telefone || '';\nconst telefone = remoteJid.replace('@s.whatsapp.net', '').replace('@g.us', '');\n\nconst mensagem = data.message?.conversation\n  || data.message?.extendedTextMessage?.text\n  || body.mensagem\n  || '';\n\nconst tipoMidia = data.message?.audioMessage ? 'audioMessage'\n  : data.message?.conversation || data.message?.extendedTextMessage ? 'texto'\n  : body.tipo_midia || 'texto';\n\nconst urlMidia = data.message?.audioMessage?.url\n  || data.message?.audioMessage?.directPath\n  || body.url_midia\n  || '';\n\nreturn [{ json: { telefone, mensagem, tipoMidia, urlMidia } }];"
      }
    },
    {
      "id": "node-validar-dono",
      "name": "Validar Dono",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3.2,
      "position": [680, 300],
      "parameters": {
        "rules": {
          "values": [
            {
              "conditions": {
                "conditions": [
                  {
                    "leftValue": "={{ $json.mensagem }}",
                    "rightValue": ".",
                    "operator": { "type": "string", "operation": "equals" }
                  }
                ],
                "combinator": "and",
                "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict", "version": 1 }
              },
              "renameOutput": true,
              "outputKey": "toggle_ia"
            },
            {
              "conditions": {
                "conditions": [
                  {
                    "leftValue": "={{ $json.telefone }}",
                    "rightValue": "={{ $env.DONO_TELEFONE }}",
                    "operator": { "type": "string", "operation": "equals" }
                  },
                  {
                    "leftValue": "={{ $json.mensagem }}",
                    "rightValue": "#admin",
                    "operator": { "type": "string", "operation": "startsWith" }
                  }
                ],
                "combinator": "and",
                "options": { "caseSensitive": false, "leftValue": "", "typeValidation": "strict", "version": 1 }
              },
              "renameOutput": true,
              "outputKey": "admin_autorizado"
            }
          ]
        },
        "options": { "fallbackOutput": "none" }
      }
    },
